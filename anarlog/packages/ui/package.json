    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "postcss": "^8.5.9",
    "react": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.6.3"
  }
