{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**", ".output/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {},
    "dev": {
      "persistent": true,
      "cache": false
    },
    "tauri:dev": {
      "persistent": true,
      "cache": false
    },
    "tauri:build": {
      "cache": false
    }
  }
}
